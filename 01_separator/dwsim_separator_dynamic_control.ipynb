   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "t_min = t_hist / 60  # convert seconds to minutes\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(12, 8), sharex=True)\n",
    "fig.subplots_adjust(hspace=0.35)\n",
    "\n",
    "# ── Pressure control ──────────────────────────────────────────────────────────\n",
    "ax1.plot(t_min, p_hist,  color=\"steelblue\", lw=2,        label=\"Pressure PV\")\n",
    "ax1.step(t_min, sp_hist, color=\"tomato\",    lw=1.5, ls=\"--\",\n",
    "         where=\"post\",                                    label=\"Setpoint SP\")\n",
    "ax1.axvline(3,  color=\"orange\", ls=\":\", lw=1, alpha=0.8, label=\"Event: SP -> 5 bar (t = 3 min)\")\n",
    "ax1.axvline(10, color=\"green\",  ls=\":\", lw=1, alpha=0.8, label=\"Event: SP -> 2 bar (t = 10 min)\")\n",
    "ax1.set_ylabel(\"Pressure (bar)\")\n",
    "ax1.set_title(\"Separator Pressure Control - PID-012\")\n",
    "ax1.legend(fontsize=9)\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# ── Level control ─────────────────────────────────────────────────────────────\n",
    "ax2.plot(t_min, lv_hist, color=\"steelblue\", lw=2,   label=\"Level PV\")\n",
    "ax2.axhline(0.3, color=\"tomato\", ls=\"--\", lw=1.5,   label=\"Setpoint (0.3 m)\")\n",
    "ax2.axvline(3,  color=\"orange\", ls=\":\", lw=1, alpha=0.8)\n",
    "ax2.axvline(10, color=\"green\",  ls=\":\", lw=1, alpha=0.8)\n",
    "ax2.set_xlabel(\"Time (min)\")\n",
    "ax2.set_ylabel(\"Level (m)\")\n",
    "ax2.set_title(\"Separator Level Control - PID-013\")\n",
    "ax2.legend(fontsize=9)\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "plt.suptitle(\n",
    "    \"Gas-Liquid Separator - Dynamic Simulation (DWSIM headless via Python)\\n\"\n",
    "    f\"Step: {dt} s  |  Duration: {t_end // 60} min  |  Speedup: {speedup:.0f}x real time\",\n",
    "    fontsize=11, fontweight=\"bold\"\n",
    ")\n",
    "\n",
    "plt.savefig(\"separator_baseline.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "print(\"Saved: separator_baseline.png\")"
   ]
